<Window
    x:Class="secure_player.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:secure_player"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    Loaded="Window_Loaded"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Image x:Name="VideoImage" Stretch="Uniform" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="PlayButton"
                    Grid.Column="0"
                    Click="PlayButton_Click"
                    Content="재생" />
                <Button
                    x:Name="PauseButton"
                    Grid.Column="1"
                    Click="PauseButton_Click"
                    Content="일시정지" />
                <Button
                    x:Name="StopButton"
                    Grid.Column="2"
                    Click="StopButton_Click"
                    Content="정지" />
                <Button
                    x:Name="Speed1xButton"
                    Grid.Column="3"
                    Click="Speed1xButton_Click"
                    Content="1x" />
                <Button
                    x:Name="Speed2xButton"
                    Grid.Column="4"
                    Click="Speed2xButton_Click"
                    Content="2x" />
                <Button
                    x:Name="Speed4xButton"
                    Grid.Column="5"
                    Click="Speed4xButton_Click"
                    Content="4x" />
            </Grid>

            <Slider Grid.Row="1" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
